{
  "name": "abstract-etl-v3",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "prepare": "husky",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint . --cache",
    "format": "prettier --write .",
    "knip": "knip",
    "validate": "npm run typecheck && npm run lint && (npm run knip || cmd /c \"exit 0\")"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "knip": "^5.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^7.0.0"
  }
}
